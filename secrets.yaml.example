# Copy to secrets.yaml (gitignored) and replace with your OWN values.
# The API keys must be valid 32-byte base64 noise PSKs. Generate real ones with:
#   openssl rand -base64 32
# The placeholders below are syntactically valid so `esphome config` / CI pass,
# but you MUST replace them before flashing anything you care about.
wifi_ssid: "your-iot-ssid"
wifi_password: "your-wifi-password"

# Downstairs unit
quietcool_lora32_api_key: "ZXNwaG9tZS1xdWlldGNvb2wtZXhhbXBsZS1rZXktMDE="
quietcool_lora32_ota_password: "change-me-ota"
quietcool_lora32_fallback_ap_password: "change-me-ap"

# HiLetgo/Heltec ESP32 LoRa V3 unit (SX1262) — only if you build quietcool-lora-v3.yaml
quietcool_lora_v3_api_key: "ZXNwaG9tZS1xdWlldGNvb2wtZXhhbXBsZS1rZXktMDM="
quietcool_lora_v3_ota_password: "change-me-ota"
quietcool_lora_v3_fallback_ap_password: "change-me-ap"
